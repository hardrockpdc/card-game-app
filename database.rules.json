{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ( (!data.exists() && newData.child('host').val() === auth.uid) || (data.exists() && !newData.exists() && data.child('host').val() === auth.uid) || (data.exists() && newData.exists() && data.child('host').val() === auth.uid && newData.child('host').val() === auth.uid) )",

        "host": { ".validate": "newData.isString() && newData.val().length <= 128" },
        "gameId": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "status": { ".validate": "newData.val() === 'waiting' || newData.val() === 'playing'" },

        "players": {
          "$uid": {
            ".write": "auth != null && ( $uid === auth.uid || root.child('rooms').child($code).child('host').val() === auth.uid )",
            "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "isHost": { ".validate": "newData.isBoolean()" },
            ".validate": "!newData.exists() || newData.hasChildren(['name'])"
          }
        },

        "net": {
          "broadcast": {
            ".write": "auth != null && root.child('rooms').child($code).child('host').val() === auth.uid",
            "$type": {
              "payload": { ".validate": "newData.isString() && newData.val().length <= 500000" }
            }
          },
          "private": {
            ".write": "auth != null && root.child('rooms').child($code).child('host').val() === auth.uid",
            "$uid": {
              "$type": {
                "payload": { ".validate": "newData.isString() && newData.val().length <= 500000" }
              }
            }
          },
          "toHost": {
            ".write": "auth != null && root.child('rooms').child($code).child('players').child(auth.uid).exists()",
            "$pushId": {
              "sender": { ".validate": "newData.isString() && newData.val().length <= 128" },
              "payload": { ".validate": "newData.isString() && newData.val().length <= 500000" }
            }
          }
        }
      }
    }
  }
}
